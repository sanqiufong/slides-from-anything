# Local runtime data — auto-created by the daemon on first start.
# Holds app.sqlite (project metadata), projects/<id>/ (per-project artifacts,
# the agent's CWD), and artifacts/ (one-off renders). Never commit.
.od
.od-e2e
test-results
playwright-report
e2e/.od-data
e2e/playwright-report
e2e/reports/html
e2e/reports/playwright-html-report
e2e/reports/test-results
e2e/reports/results.json
e2e/reports/junit.xml
e2e/reports/latest.md

# Design Vault runtime/source material. Keep the software, exclude imported
# designs, captured website assets, generated previews, and community staging.
apps/design-vault/data/*
!apps/design-vault/data/.gitkeep
apps/design-vault/tmp/
apps/design-vault/.local/
skills/dv-*/
design-systems/dv-*/

